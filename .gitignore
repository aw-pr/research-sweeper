# Dependencies
node_modules/

# Build output
dist/

# Environment
.env
.env.*
!.env.example
*.local
.env.bak

# Secret key material (never commit)
*.pem
*.key
*.p12
*.pfx

# Private 1Password ref override (keep .example committed)
op-refs.local.sh
op-refs.local.sh.bak

# Publish guard personal patterns + machine-specific notes (.example tracked)
.publish-guard.local
/LOCAL.md

# Local Claude Code settings + runtime state (machine-specific)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/*.lock

# Research output (large generated files)
research-output/
output/
# results/ is ignored by default; the three curated sample outputs below are
# deliberately tracked as worked examples. Do NOT add a broad !results/2026-*
# negation — that would re-expose the scrubbed political result.
results/
!results/2026-04-07-ai-software-engineering-trends-2026.md
!results/2026-04-07-certification-options-claude-code-codex.md
!results/2026-04-07-technology-trends-market-reactions.md
logs/

# Test run output folders
test-*/
tmp-runs/

# Archives
*.tar.gz

# Batch job state
jobs/

# Runs directory: ignore job/state JSON and logs, keep stats.json tracked
runs/*.json
runs/*.log
!runs/stats.json

# macOS
.DS_Store
