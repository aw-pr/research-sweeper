# Copy to .env and fill in if you do NOT use 1Password.
#
# Loaded fill-only at startup: a value here is used ONLY when the variable is
# not already set in the environment. It never overrides a real shell export
# or a key injected by the op-fetch / 1Password route, so it is safe to keep
# this file alongside a 1Password setup.
#
# .env.local takes precedence over .env (both are gitignored except this
# .example). Provide whichever providers you intend to use.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Subscription (Max/Pro) sync route — generate with `claude setup-token`:
CLAUDE_CODE_OAUTH_TOKEN=
GEMINI_API_KEY=
# GCP-billed OAuth sync route — supply a valid Bearer token from `gcloud auth print-access-token`:
GOOGLE_ACCESS_TOKEN=

# Where generated research output is written.
# Default: ~/obsidian/research
# RESEARCH_SWEEPER_OUTPUT_DIR=/absolute/path/to/output

# 1Password users: leave this file empty and instead copy
# op-refs.local.sh.example to op-refs.local.sh with your vault refs.
