#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
HELPER_RUNNER="$ROOT_DIR/run-secure-command.sh"
CODEX_AUTH_FILE="$HOME/.codex/auth.json"

if [ -f "$ROOT_DIR/.env" ] && [ "${RESEARCH_SWEEPER_HELPER_ACTIVE:-}" != "1" ]; then
  exec "$HELPER_RUNNER" npx --prefix "$ROOT_DIR" ts-node "$ROOT_DIR/src/mcp-server.ts" "$@"
fi

if [ -z "${ANTHROPIC_API_KEY:-}" ] && [ -z "${OPENAI_API_KEY:-}" ] && [ ! -f "$CODEX_AUTH_FILE" ]; then
  echo "[research-sweeper-mcp] Warning: no helper-backed env, provider API keys, or Codex auth detected" >&2
fi

exec npx --prefix "$ROOT_DIR" ts-node "$ROOT_DIR/src/mcp-server.ts" "$@"
